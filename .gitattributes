* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts keep LF
*.sh text eol=lf
